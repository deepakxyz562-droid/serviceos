// ==========================================
// LEAD DISCOVERY MODULE
// ==========================================
// Find Local Businesses → Import to CRM → Launch Outreach → Track Conversions
// Sources: Google Places, Facebook Pages, Website Import, CSV Import, Manual Entry

model LeadDiscovery {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  email           String?
  website         String?
  address         String?
  city            String?
  state           String?
  country         String   @default("US")
  postalCode      String?
  latitude        Float?
  longitude       Float?
  // ─── Source tracking ───
  source          String   @default("manual")  // google_places, facebook, website, csv, manual
  externalId      String?  // Google Place ID, Facebook Page ID, etc.
  sourceUrl       String?  // URL of the source listing
  sourceDataJson  String   @default("{}")  // Raw data from the source (ratings, reviews, etc.)
  // ─── Business details ───
  businessType    String?  // restaurant, salon, plumbing, etc.
  category        String?  // Google Places type / Facebook category
  rating          Float    @default(0)  // External rating (Google/Facebook)
  reviewCount     Int      @default(0)  // Number of external reviews
  description     String?  // Business description from source
  // ─── Discovery pipeline status ───
  status          String   @default("discovered")  // discovered, contacted, imported, qualified, converted, dismissed
  priority        String   @default("medium")  // low, medium, high, hot
  // ─── Import tracking ───
  leadId          String?  // Once imported to CRM, links to the Lead
  campaignId      String?  // If added to an outreach campaign
  importedAt      DateTime?
  contactedAt     DateTime?
  convertedAt     DateTime?
  // ─── Tags & notes ───
  tagsJson        String   @default("[]")
  notesJson       String   @default("[]")
  // ─── Search context ───
  searchQueryId   String?  // Links to LeadDiscoverySearch for context
  tenantId        String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant? @relation(fields: [tenantId], references: [id])
  search  LeadDiscoverySearch? @relation(fields: [searchQueryId], references: [id])

  @@index([tenantId])
  @@index([source])
  @@index([status])
  @@index([businessType])
  @@index([priority])
  @@index([createdAt])
  @@index([leadId])
}

model LeadDiscoverySearch {
  id              String   @id @default(cuid())
  query           String   // e.g., "plumbers in Mumbai", "restaurants near downtown"
  source          String   @default("google_places")  // google_places, facebook, website, csv, manual
  location        String?  // e.g., "Mumbai, India", "New York, NY"
  latitude        Float?
  longitude       Float?
  radius          Int      @default(5000)  // Search radius in meters
  businessType    String?  // Filter by business type
  // ─── Results tracking ───
  resultsCount    Int      @default(0)
  importedCount   Int      @default(0)
  contactedCount  Int      @default(0)
  convertedCount  Int      @default(0)
  // ─── API config ───
  apiConfigJson   String   @default("{}")  // Store API-specific params (Google Places types, etc.)
  // ─── Status ───
  status          String   @default("completed")  // searching, completed, failed
  lastSearchedAt  DateTime?
  tenantId        String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  discoveries LeadDiscovery[]

  @@index([tenantId])
  @@index([source])
  @@index([status])
  @@index([createdAt])
}
