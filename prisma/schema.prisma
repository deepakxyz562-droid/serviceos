// ==========================================
// COMMUNICATION PROVIDERS
// ==========================================

model CommunicationProvider {
  id              String   @id @default(cuid())
  name            String   // e.g., "Twilio SMS", "Amazon SES"
  type            String   // whatsapp, email, sms  (NOTE: 'email' is deprecated — use EmailProvider instead)
  provider        String   // twilio, msg91, plivo, textlocal, exotel, amazon_ses, resend, sendgrid, mailgun, postmark, meta_cloud_api, 360dialog, wati, interakt, gupshup
  status          String   @default("active") // active, inactive, error
  configJson      String   @default("{}")  // Provider-specific config (API keys, tokens, SMTP settings)
  credentialId    String?  // Optional: link to a Credential from the vault instead of duplicating secrets here
  isDefault       Boolean  @default(false)
  sendingEnabled  Boolean  @default(true)
  dailyLimit      Int      @default(1000)
  monthlyLimit    Int      @default(30000)
  sentToday       Int      @default(0)
  sentThisMonth   Int      @default(0)
  totalSent       Int      @default(0)
  totalDelivered  Int      @default(0)
  totalFailed     Int      @default(0)
  lastUsedAt      DateTime?
  lastError       String?
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  credential Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([provider])
  @@index([status])
  @@index([tenantId])
  @@index([credentialId])
}

// ==========================================
// CONTACTS — Master audience database
// Enterprise CRM structure: Contacts → Groups → Tags → Segments → Campaigns
// ==========================================

model Contact {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  // Location (used by Segment rules)
  city            String?
  state           String?
  country         String?
  zip             String?
  // Source / lifecycle
  source          String?  // manual, csv_import, form, whatsapp, ads, api
  status          String   @default("active")  // active, bounced, unsubscribed, blocked
  emailVerified   Boolean  @default(false)
  phoneVerified   Boolean  @default(false)
  // Extensibility
  customFieldsJson String  @default("{}")
  avatarUrl       String?
  lastActivityAt  DateTime?
  // LEGACY: kept for backward compatibility. New system uses ContactTag (M2M).
  tags            String?   // comma separated (legacy)
  tenantId        String
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  contactTags     ContactTag[]
  contactGroups   ContactGroup[]

  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([status])
  @@index([source])
  @@index([country])
  @@index([city])
}

