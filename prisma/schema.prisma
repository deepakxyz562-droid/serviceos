// Universal Webhook Endpoint — receives inbound webhooks from any source (WordPress, Zapier, custom forms, etc.)
model WebhookEndpoint {
  id            String   @id @default(cuid())
  name          String                    // e.g., "WordPress Lead Capture"
  endpointId    String   @unique          // Unique path segment: /api/webhooks/ingest/{endpointId}
  apiKeyHash    String                    // Hash of the API key for authentication
  apiKeyPrefix  String                    // First 8 chars for display: "sos_prod_••••"
  source        String   @default("universal") // wordpress, zapier, custom, universal
  active        Boolean  @default(true)
  leadSource    String   @default("webhook")   // Value for Lead.source field
  fieldMapping  String   @default("{}")        // JSON: source field → lead field mapping
  autoCreateCustomer Boolean @default(true)
  sendWhatsApp  Boolean  @default(true)
  whatsappOwnerPhone String @default("")    // Owner WhatsApp number for notifications
  whatsappOwnerTemplate String @default("") // WhatsApp template sent to owner on lead
  whatsappUserTemplate  String @default("") // WhatsApp template sent to user/form submitter
  whatsappAiGenerated  Boolean @default(false) // AI-generate user WhatsApp message
  whatsappTemplate String @default("new_lead")
  tenantId      String?
  workspaceId   String?
  totalReceived Int      @default(0)
  lastReceived  DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          WebhookEndpointLog[]

  @@index([endpointId])
  @@index([apiKeyHash])
  @@index([tenantId])
  @@index([active])
}

