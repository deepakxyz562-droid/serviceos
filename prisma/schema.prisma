  workspaceId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([stage])
  @@index([assigneeId])
  @@index([customerId])
  @@index([tenantId])
}

model DealStageHistory {
  id          String   @id @default(cuid())
  dealId      String
  fromStage   String?
  toStage     String
  changedById String?
  note        String?
  createdAt   DateTime @default(now())

  @@index([dealId])
  @@index([toStage])
  @@index([createdAt])
}

// --- Module 15: Omnichannel Communication ---
// ChannelConfig model is defined above in the OMNICHANNEL CONFIGURATION section

model UnifiedMessage {
  id              String   @id @default(cuid())
  channelId       String?  // FK to ChannelConfig
  channel         String   @default("whatsapp")  // whatsapp, email, sms, instagram, facebook, telegram
  direction       String   @default("inbound")  // inbound, outbound
  senderId        String?
  senderName      String?
  recipientId     String?
  recipientName   String?
  subject         String?
  content         String
  contentType     String   @default("text")  // text, html, image, video
  mediaUrl        String?
  externalId      String?
  threadId        String?  // conversation thread
  customerId      String?
  status          String   @default("sent")  // sent, delivered, read, failed
  metadataJson    String   @default("{}")
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([channel])
  @@index([direction])
  @@index([customerId])
  @@index([tenantId])
  @@index([createdAt])
}

// --- Module 16: Workflow Marketplace ---

model MarketplaceTemplate {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String   // lead_follow_up, appointment_reminder, payment_reminder, review_collection, win_back
  subcategory     String?
  workflowJson    String   @default("{}")
  icon            String?
  color           String?
  author          String?
  authorAvatar    String?
  downloads       Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  featured        Boolean  @default(false)
  premium         Boolean  @default(false)
  price           Float    @default(0)
  currency        String   @default("USD")
  tagsJson        String   @default("[]")
  screenshotsJson String   @default("[]")
  tenantId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([featured])
  @@index([downloads])
}

// --- Module 17: Enterprise Features ---

model RolePermission {
  id          String   @id @default(cuid())
  role        String   // owner, manager, dispatcher, employee, customer, superadmin
  resource    String   // conversations, campaigns, chatbots, segments, deals, etc.
  actionsJson String   @default("[]")  // ["create", "read", "update", "delete", "assign", "approve"]
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([role, resource, tenantId])
  @@index([role])
  @@index([tenantId])
}

model AgentMonitor {
  id              String   @id @default(cuid())
  agentId         String   // userId
  agentName       String?
  status          String   @default("online")  // online, offline, busy, away
  activeChats     Int      @default(0)
  resolvedToday   Int      @default(0)
  avgResponseTime Float    @default(0)  // in seconds
  avgResolutionTime Float  @default(0)  // in minutes
  customerSatisfaction Float @default(0)
  lastActivityAt  DateTime @default(now())
  shiftStart      String?  // HH:mm
  shiftEnd        String?  // HH:mm
  tenantId        String?
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([tenantId])
}

model DataRetentionPolicy {
  id              String   @id @default(cuid())
  resourceType    String   // conversations, messages, campaigns, audit_logs, notifications
  retentionDays   Int      @default(365)
  autoDelete      Boolean  @default(false)
  archiveFirst    Boolean  @default(true)
  tenantId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([resourceType, tenantId])
  @@index([tenantId])
}

model ConversationExport {
  id              String   @id @default(cuid())
  requestedById   String?
  format          String   @default("json")  // json, csv, pdf
  status          String   @default("pending")  // pending, processing, completed, failed
  filtersJson     String   @default("{}")
  fileUrl         String?
  recordCount     Int      @default(0)
  error           String?
  tenantId        String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([requestedById])
  @@index([status])
  @@index([tenantId])
}

// ==========================================
// COMMUNICATION PROVIDERS
// ==========================================

model CommunicationProvider {
  id              String   @id @default(cuid())
  name            String   // e.g., "Twilio SMS", "Amazon SES"
  type            String   // whatsapp, email, sms
  provider        String   // twilio, msg91, plivo, textlocal, exotel, amazon_ses, resend, sendgrid, mailgun, postmark, meta_cloud_api, 360dialog, wati, interakt, gupshup
  status          String   @default("active") // active, inactive, error
  configJson      String   @default("{}")  // Provider-specific config (API keys, tokens, SMTP settings)
  isDefault       Boolean  @default(false)
  sendingEnabled  Boolean  @default(true)
  dailyLimit      Int      @default(1000)
  monthlyLimit    Int      @default(30000)
  sentToday       Int      @default(0)
  sentThisMonth   Int      @default(0)
  totalSent       Int      @default(0)
  totalDelivered  Int      @default(0)
  totalFailed     Int      @default(0)
  lastUsedAt      DateTime?
  lastError       String?
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([provider])
  @@index([status])
  @@index([tenantId])
}

// ==========================================
// CONTACTS
// ==========================================

model Contact {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  tags        String?   // comma separated
  tenantId    String
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([createdAt])
}

// ==========================================
// TRIGGER EXECUTION LOG
// ==========================================

model TriggerExecution {
  id              String   @id @default(cuid())
  automationId    String   // FK to WorkflowAutomation
  triggerEvent    String   // The event that fired (e.g., lead.created)
  triggerPayload  String   @default("{}") // JSON payload of the trigger event
  conditionsMet   Boolean  @default(true) // Were conditions satisfied?
  actionsResultsJson String @default("[]") // Results of each action execution
  status          String   @default("success") // success, failed, partial
  error           String?
  durationMs      Int?
  tenantId        String?
  createdAt       DateTime @default(now())

  automation WorkflowAutomation? @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([triggerEvent])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
}
