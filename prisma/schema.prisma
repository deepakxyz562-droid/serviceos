generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// MULTI-TENANT CORE
// ==========================================

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  industry          String?
  logo              String?
  phone             String?
  email             String?
  address           String?
  country           String   @default("US")
  currency          String   @default("USD")
  whatsappPhone     String?
  whatsappConfigJson String @default("{}")
  plan              String   @default("starter")
  planStatus        String   @default("trial")
  trialEndsAt       DateTime?
  planStartedAt     DateTime?
  planEndsAt        DateTime?
  settingsJson      String   @default("{}")
  onboardingCompleted Boolean @default(false)
  onboardingStep    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users           User[]
  workspaces      Workspace[]
  leads           Lead[]
  invoices        Invoice[]
  subscriptions   Subscription[]
  services        Service[]
  reviews         Review[]
  notifications   Notification[]
  quotes          Quote[]
  notificationLogs NotificationLog[]
  conversations   Conversation[]
  forms           Form[]
  workflowAutomations WorkflowAutomation[]

  @@index([slug])
  @@index([plan])
}

model Subscription {
  id                      String   @id @default(cuid())
  tenantId                String
  plan                    String
  status                  String   @default("trial")
  amount                  Float    @default(0)
  currency                String   @default("USD")
  billingCycle            String   @default("monthly")
  startDate               DateTime @default(now())
  endDate                 DateTime?
  trialEndsAt             DateTime?
  paypalSubscriptionId    String?
  paypalPlanId            String?
  paypalOrderId           String?
  paypalPayerEmail        String?
  paymentProvider         String   @default("none")
  maxUsers                Int      @default(1)
  maxJobs                 Int      @default(100)
  maxWorkflows            Int      @default(10)
  featuresJson            String   @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  avatar          String?
  role            String   @default("owner")
  authProvider    String   @default("email")
  authProviderId  String?
  phone           String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id])
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  workflows    Workflow[]  @relation("WorkflowCreator")
  credentials  Credential[] @relation("CredentialOwner")
  notifications Notification[]
  employeeAccount Employee?
  employeeStatusLogs EmployeeStatusLog[]

  @@index([email])
  @@index([tenantId])
}

// ==========================================
// SERVICE CATALOG
// ==========================================

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("general")
  basePrice   Float    @default(0)
  duration    Int      @default(60)
  icon        String?
  isActive    Boolean  @default(true)
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
}

// ==========================================
// LEAD MANAGEMENT
// ==========================================

model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String   @default("manual")
  status          String   @default("new")
  priority        String   @default("medium")
  value           Float    @default(0)
  description     String?
  address         String?
  serviceType     String?
  serviceId       String?
  assignedToId    String?
  tenantId        String?
  customerId      String?
  jobId           String?  @unique
  notesJson       String   @default("[]")
  tagsJson        String   @default("[]")
  followUpAt      DateTime?
  convertedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  job        Job?      @relation(fields: [jobId], references: [id])
  assignedTo Employee? @relation(fields: [assignedToId], references: [id])
  conversation Conversation?
  journey      CustomerJourney?

  @@index([tenantId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// ==========================================
// INVOICES
// ==========================================

model Invoice {
  id          String    @id @default(cuid())
  number      String    @unique
  tenantId    String?
  jobId       String?
  customerId  String?
  employeeId  String?
  amount      Float     @default(0)
  tax         Float     @default(0)
  discount    Float     @default(0)
  total       Float     @default(0)
  currency    String    @default("USD")
  status      String    @default("draft")
  dueDate     DateTime?
  paidAt      DateTime?
  itemsJson   String    @default("[]")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
}

// ==========================================
// REVIEWS
// ==========================================

model Review {
  id          String   @id @default(cuid())
  rating      Int      @default(5)
  comment     String?
  jobId       String?  @unique
  customerId  String?
  employeeId  String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([rating])
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  userId    String?
  tenantId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([read])
}

// ==========================================
// QUOTES
// ==========================================

model Quote {
  id            String    @id @default(cuid())
  title         String
  description   String?
  itemsJson     String    @default("[]")  // Service line items with serviceId, name, price, qty
  addOnsJson    String    @default("[]")  // Add-on items with name, price
  subtotal      Float     @default(0)
  tax           Float     @default(0)
  taxRate       Float     @default(0)     // Tax percentage
  discount      Float     @default(0)
  discountType  String    @default("fixed") // fixed, percentage
  total         Float     @default(0)
  status        String    @default("draft") // draft, sent, accepted, rejected, expired
  tenantId      String?
  customerId    String?
  leadId        String?
  validUntil    DateTime?
  whatsappSent  Boolean   @default(false)
  whatsappSentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
}

// ==========================================
// FORM BUILDER
// ==========================================

model Form {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  type                String   @default("lead_capture") // lead_capture, booking, feedback, survey, quote_request, job_request, custom
  status              String   @default("active") // active, inactive, archived
  fieldsJson          String   @default("[]")     // Array of form field definitions
  submissionActions   String   @default("[]")     // Array of actions: create_lead, create_customer, create_booking, create_job, create_quote, store_response, send_whatsapp, send_email, trigger_workflow, call_webhook
  fieldMappingJson    String   @default("{}")     // Form field → CRM field mapping
  welcomeMessage      String   @default("")
  completionMessage   String   @default("")
  whatsappOwnerTemplate String  @default("")     // WhatsApp template sent to owner on submission
  whatsappUserTemplate  String  @default("")     // WhatsApp template sent to user on submission
  whatsappAiGenerated  Boolean @default(false)   // AI-generate user WhatsApp confirmation
  embedScriptEnabled  Boolean  @default(false)
  embedIframeEnabled  Boolean  @default(false)
  slug                String?  @unique           // For embed URLs
  submissions         Int      @default(0)
  conversionRate      Float    @default(0)
  tenantId            String?
  workspaceId         String?
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  responses FormResponse[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([slug])
}

model FormResponse {
  id          String   @id @default(cuid())
  formId      String
  dataJson    String   @default("{}")  // Key-value pairs of form responses
  respondent  String?  // Phone or email of submitter
  respondentName String?
  source      String   @default("direct") // direct, whatsapp, embed, wordpress, webhook
  leadId      String?  // If a lead was created from this response
  customerId  String?  // If a customer was created
  jobId       String?  // If a job was created
  quoteId     String?  // If a quote was created
  bookingId   String?  // If a booking was created
  actionsResultsJson String @default("{}") // Results of submission actions
  tenantId    String?
  createdAt   DateTime @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([source])
  @@index([tenantId])
  @@index([createdAt])
}

// ==========================================
// WORKFLOW AUTOMATION (Enhanced)
// ==========================================

model WorkflowAutomation {
  id            String   @id @default(cuid())
  name          String
  description   String?
  triggerType   String   // lead.created, lead.assigned, lead.status_changed, lead.converted, customer.created, quote.sent, quote.accepted, quote.rejected, booking.created, booking.confirmed, booking.cancelled, job.created, job.assigned, job.completed, job.cancelled, employee.assigned, whatsapp.message_received, form.submitted, invoice.created, invoice.paid, invoice.overdue, time.based
  triggerConfigJson String @default("{}") // Trigger-specific config (e.g., time delays, field filters)
  conditionsJson String  @default("[]")   // Array of condition objects { field, operator, value }
  actionsJson   String   @default("[]")   // Array of action objects { type, config }
  active        Boolean  @default(true)
  executionCount Int     @default(0)
  lastExecutedAt DateTime?
  lastExecutionStatus String? // success, failed
  tagsJson      String   @default("[]")
  tenantId      String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  executions TriggerExecution[]

  @@index([tenantId])
  @@index([triggerType])
  @@index([active])
}

// ==========================================
// WORKFLOW AUTOMATION
// ==========================================

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  industry      String?
  logo          String?
  plan          String   @default("free")
  planExpiresAt DateTime?
  ownerId       String
  tenantId      String?
  settingsJson  String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  users         User[]
  workflows     Workflow[]
  credentials   Credential[]
  variables     Variable[]
  employees     Employee[]
  customers     Customer[]
  resources     Resource[]
  jobs          Job[]
  contactLists  ContactList[]
  folders       Folder[]
  webhookSources WebhookSource[]

  @@index([tenantId])
}

model Workflow {
  id            String   @id @default(cuid())
  name          String
  description   String?
  nodesJson     String   @default("[]")
  edgesJson     String   @default("[]")
  settingsJson  String   @default("{}")
  active        Boolean  @default(false)
  tags          String   @default("[]")
  folderId      String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  createdBy    User?         @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  versions     WorkflowVersion[]
  executions   Execution[]
  webhooks     WebhookRegistration[]
  folder       Folder?       @relation(fields: [folderId], references: [id])

  @@index([workspaceId])
  @@index([active])
}

model WorkflowVersion {
  id           String   @id @default(cuid())
  workflowId   String
  snapshotJson String
  message      String?
  createdById  String?
  createdAt    DateTime @default(now())
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Credential {
  id            String   @id @default(cuid())
  name          String
  type          String
  encryptedData String
  workspaceId   String?
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation("CredentialOwner", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Execution {
  id           String    @id @default(cuid())
  workflowId   String
  status       String    @default("running")
  mode         String    @default("manual")
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  dataJson     String    @default("{}")
  errorJson    String?
  durationMs   Int?
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeData     ExecutionNodeData[]

  @@index([workflowId])
  @@index([status])
}

model ExecutionNodeData {
  id          String   @id @default(cuid())
  executionId String
  nodeName    String
  nodeId      String
  inputJson   String   @default("[]")
  outputJson  String   @default("[]")
  errorJson   String?
  durationMs  Int?
  status      String   @default("success")
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model WebhookRegistration {
  id          String   @id @default(cuid())
  workflowId  String
  path        String
  method      String   @default("POST")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([path])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  metadataJson String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String
  name      String
  scopes    String   @default("[]")
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@unique([keyHash])
}

model Variable {
  id             String   @id @default(cuid())
  key            String
  valueEncrypted String
  workspaceId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])

  @@unique([key, workspaceId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workflows   Workflow[]
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    Folder[] @relation("FolderHierarchy")

  @@index([workspaceId])
}

model Template {
  id           String   @id @default(cuid())
  name         String
  description  String?
  workflowJson String
  category     String
  icon         String?
  featured     Boolean  @default(false)
  usageCount   Int      @default(0)
  rating       Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ==========================================
// BUSINESS OPERATIONS
// ==========================================

model Employee {
  id              String    @id @default(cuid())
  name            String
  phone           String
  email           String?
  role            String    @default("technician")
  skills          String    @default("[]")
  status          String    @default("available")
  avatar          String?
  whatsappId      String?
  rating          Float     @default(0)
  completedJobs   Int       @default(0)
  location        String?
  latitude        Float?
  longitude       Float?
  workspaceId     String?
  lastSeenAt      DateTime?
  currentJobId    String?   @unique
  userId          String?   @unique
  lastLocationAt  DateTime?
  onLeaveUntil    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace?              @relation(fields: [workspaceId], references: [id])
  assignedJobs    Job[]                   @relation("JobAssignee")
  leads           Lead[]
  invoices        Invoice[]
  currentJob      Job?                    @relation("EmployeeCurrentJob", fields: [currentJobId], references: [id])
  userAccount     User?                   @relation(fields: [userId], references: [id])
  statusLogs      EmployeeStatusLog[]
  notificationLogs NotificationLog[]

  @@index([role])
  @@index([status])
  @@index([workspaceId])
  @@index([lastSeenAt])
  @@index([currentJobId])
  @@index([userId])
}

model EmployeeStatusLog {
  id           String   @id @default(cuid())
  employeeId   String
  fromStatus   String?
  toStatus     String
  reason       String?
  changedById  String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([employeeId])
  @@index([toStatus])
  @@index([createdAt])
}

model NotificationLog {
  id            String   @id @default(cuid())
  type          String   @default("whatsapp")  // whatsapp, email, sms, push, in_app
  recipient     String
  recipientName String?
  recipientRole String?  // employee, customer, manager
  subject       String?
  message       String
  status        String   @default("sent")  // sent, delivered, read, failed
  externalId    String?  // WhatsApp message ID, email message ID, etc.
  jobId         String?
  employeeId    String?
  customerId    String?
  tenantId      String?
  metadataJson  String   @default("{}")
  createdAt     DateTime @default(now())

  job      Job?      @relation(fields: [jobId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([type])
  @@index([status])
  @@index([jobId])
  @@index([employeeId])
  @@index([customerId])
  @@index([createdAt])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  address     String?
  whatsappId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  jobs      Job[]
  invoices  Invoice[]
  leads     Lead[]
  quotes    Quote[]
  notificationLogs NotificationLog[]
  conversations        Conversation[]
  journeys             CustomerJourney[]
  portalSessions       CustomerPortalSession[]

  @@index([phone])
  @@index([workspaceId])
}

model Resource {
  id            String   @id @default(cuid())
  name          String
  phone         String
  type          String   @default("driver")
  status        String   @default("available")
  skills        String   @default("[]")
  location      String?
  avatar        String?
  whatsappId    String?
  rating        Float    @default(0)
  completedJobs Int      @default(0)
  metadataJson  String?
  workspaceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  assignedJobs Job[]      @relation("JobResource")

  @@index([type])
  @@index([status])
}

model Job {
  id                 String    @id @default(cuid())
  jobNumber          String?
  title              String
  description        String?
  status             String    @default("pending")
  priority           String    @default("medium")
  type               String    @default("service")
  address            String?
  pickup             String?
  dropoff            String?
  scheduledAt        DateTime?
  scheduledTime      String?
  estimatedDuration  Int?
  actualStartTime    DateTime?
  actualEndTime      DateTime?
  notes              String?
  customerId         String?
  customerName       String?
  customerPhone      String?
  assigneeId         String?
  assigneeName       String?
  assigneePhone      String?
  resourceId         String?
  serviceId          String?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  customerRating     Int?
  employeeRating     Int?
  externalId         String?
  externalSource     String?
  whatsappMessageId  String?
  whatsappSessionId  String?
  assignmentStatus   String?
  notificationLogJson String @default("[]")
  workspaceId        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  assignee   Employee?  @relation("JobAssignee", fields: [assigneeId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  resource   Resource?  @relation("JobResource", fields: [resourceId], references: [id])
  lead       Lead?
  invoices   Invoice[]
  currentEmployee Employee? @relation("EmployeeCurrentJob")
  notificationLogs NotificationLog[]
  conversation      Conversation?
  journey           CustomerJourney?

  @@index([status])
  @@index([assigneeId])
  @@index([customerId])
  @@index([scheduledAt])
  @@index([workspaceId])
}

model ContactList {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("custom")
  roleFilter  String?
  icon        String?
  color       String?
  isDefault   Boolean  @default(false)
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  entries   ContactListEntry[]

  @@index([type])
  @@index([workspaceId])
}

model ContactListEntry {
  id            String   @id @default(cuid())
  contactListId String
  name          String
  phone         String
  email         String?
  role          String?
  employeeId    String?
  customerId    String?
  whatsappId    String?
  avatar        String?
  metadataJson  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contactList ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@index([contactListId])
}

model WebhookSource {
  id          String    @id @default(cuid())
  name        String
  type        String
  configJson  String    @default("{}")
  status      String    @default("active")
  lastSyncAt  DateTime?
  lastError   String?
  workspaceId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([type])
  @@index([status])
}

// Universal Webhook Endpoint — receives inbound webhooks from any source (WordPress, Zapier, custom forms, etc.)
model WebhookEndpoint {
  id            String   @id @default(cuid())
  name          String                    // e.g., "WordPress Lead Capture"
  endpointId    String   @unique          // Unique path segment: /api/webhooks/ingest/{endpointId}
  apiKeyHash    String                    // Hash of the API key for authentication
  apiKeyPrefix  String                    // First 8 chars for display: "sos_prod_••••"
  source        String   @default("universal") // wordpress, zapier, custom, universal
  active        Boolean  @default(true)
  leadSource    String   @default("webhook")   // Value for Lead.source field
  fieldMapping  String   @default("{}")        // JSON: source field → lead field mapping
  autoCreateCustomer Boolean @default(true)
  sendWhatsApp  Boolean  @default(true)
  whatsappOwnerPhone String @default("")    // Owner WhatsApp number for notifications
  whatsappOwnerTemplate String @default("") // WhatsApp template sent to owner on lead
  whatsappUserTemplate  String @default("") // WhatsApp template sent to user/form submitter
  whatsappAiGenerated  Boolean @default(false) // AI-generate user WhatsApp message
  whatsappTemplate String @default("new_lead")
  tenantId      String?
  workspaceId   String?
  totalReceived Int      @default(0)
  lastReceived  DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  logs          WebhookEndpointLog[]

  @@index([endpointId])
  @@index([apiKeyHash])
  @@index([tenantId])
  @@index([active])
}

// Log of inbound webhook requests for debugging and audit trail
model WebhookEndpointLog {
  id              String   @id @default(cuid())
  webhookEndpointId String
  sourceIp        String?
  source          String   // wordpress, zapier, custom
  payloadJson     String
  leadId          String?  // If a lead was created
  status          String   @default("received") // received, processed, error
  error           String?
  processingMs    Int?
  createdAt       DateTime @default(now())

  webhookEndpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId])
  @@index([status])
  @@index([createdAt])
}

model WebhookTestRequest {
  id              String   @id @default(cuid())
  path            String
  method          String
  headersJson     String   @default("{}")
  queryParamsJson String   @default("{}")
  bodyJson        String?
  contentType     String   @default("")
  receivedAt      DateTime @default(now())

  @@index([path])
}

model WhatsAppMessageAction {
  id                 String   @id @default(cuid())
  whatsappMessageId  String   @unique
  workflowId         String
  nodeId             String
  onSelectWebhookUrl String?
  onSelectWorkflowId String?
  nodeConfigJson     String   @default("{}")
  phoneRecipient     String
  createdAt          DateTime @default(now())

  @@index([whatsappMessageId])
  @@index([workflowId])
}

// ==========================================
// EVENT WEBHOOKS (n8n integration)
// ==========================================
// Stores external webhook URLs (e.g., n8n workflows) that ServiceOS
// calls when job events occur. This bridges the gap between
// ServiceOS job lifecycle and n8n automation workflows.

model EventWebhook {
  id            String   @id @default(cuid())
  name          String                    // e.g., "n8n - Job Created → WhatsApp Employee"
  event         String                    // job.created, job.assigned, job.accepted, job.started, job.completed, job.cancelled, job.rejected
  url           String                    // The n8n webhook URL to call (e.g., https://n8n.example.com/webhook/abc123)
  method        String   @default("POST") // HTTP method
  headersJson   String   @default("{}")   // Custom headers to send (e.g., auth headers for n8n)
  active        Boolean  @default(true)
  retryOnFail   Boolean  @default(true)   // Retry if webhook call fails
  maxRetries    Int      @default(3)
  timeoutMs     Int      @default(10000)  // Request timeout
  lastTriggered DateTime?                 // When this webhook was last fired
  lastStatus    String?                   // success, failed, timeout
  lastError     String?                   // Error message from last attempt
  failCount     Int      @default(0)      // Consecutive failures
  workspaceId   String?                   // Optional: scope to workspace
  tenantId      String?                   // Optional: scope to tenant
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([event])
  @@index([active])
  @@index([workspaceId])
  @@index([tenantId])
}

// Log of webhook dispatches for debugging and audit trail
model EventWebhookLog {
  id            String   @id @default(cuid())
  eventWebhookId String                   // FK to EventWebhook
  event         String                    // The event that triggered this
  jobId         String?                   // Related job
  payloadJson   String                    // The JSON payload sent
  responseStatus Int?                     // HTTP status code received
  responseBody  String?                   // Response body (truncated)
  error         String?                   // Error if failed
  durationMs    Int?                      // How long the webhook call took
  retried       Boolean  @default(false)  // Was this a retry?
  createdAt     DateTime @default(now())

  @@index([eventWebhookId])
  @@index([event])
  @@index([jobId])
  @@index([createdAt])
}

