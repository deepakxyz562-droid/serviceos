model ContactTag {
  id          String   @id @default(cuid())
  contactId   String
  tagId       String
  appliedAt   DateTime @default(now())
  appliedById String?

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// ==========================================
// GROUPS — Manual collections (folders for contacts)
// Supports sub-groups via parentGroupId (self-reference)
// ==========================================

model Group {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String?
  icon            String?
  type            String   @default("manual")  // manual, smart
  parentGroupId   String?  // for sub-groups (self-reference)
  smartRulesJson  String   @default("{}")  // used when type = 'smart'
  memberCount     Int      @default(0)
  isDefault       Boolean  @default(false)
  tenantId        String
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent          Group?          @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: SetNull)
  children        Group[]         @relation("GroupHierarchy")
  contacts        ContactGroup[]

  @@unique([tenantId, name, parentGroupId])
  @@index([tenantId])
  @@index([parentGroupId])
  @@index([type])
}

model ContactGroup {
  id          String   @id @default(cuid())
  contactId   String
  groupId     String
  addedAt     DateTime @default(now())
  addedById   String?

  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
  @@index([contactId])
  @@index([groupId])
}

// ==========================================
// CONTACT IMPORTS / EXPORTS — Job tracking
// ==========================================

model ContactImport {
  id              String   @id @default(cuid())
  fileName        String
  source          String   @default("csv")  // csv, xlsx, manual
  totalRows       Int      @default(0)
  importedCount   Int      @default(0)
  skippedCount    Int      @default(0)
  errorCount      Int      @default(0)
  status          String   @default("pending")  // pending, processing, completed, failed
  errorJson       String   @default("[]")  // first N errors with row context
  mappingJson     String   @default("{}")  // column → field mapping
  autoGroupId     String?  // optional group to auto-assign imported contacts
  tenantId        String
  workspaceId     String?
  createdById     String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model ContactExport {
  id              String   @id @default(cuid())
  format          String   @default("csv")  // csv, xlsx, json
  filterJson      String   @default("{}")  // the filter that produced this export
  totalExported   Int      @default(0)
  fileUrl         String?  // optional stored URL
  tenantId        String
  workspaceId     String?
  createdById     String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ==========================================
// EMAIL PROVIDERS — Multi-provider platform service
// Used for: authentication, portal, notifications, workflows, CRM, campaigns, invoices, bookings
// Provider types: smtp, resend, sendgrid, ses, mailgun, postmark, brevo
// ==========================================

model EmailProvider {
  id                  String   @id @default(cuid())
  name                String   // "AWS SES Production", "Resend Default"
  providerType        String   // smtp, resend, sendgrid, ses, mailgun, postmark, brevo
  // Provider-specific config JSON (different fields per type):
  //   smtp:  { smtpHost, smtpPort, smtpSecure, smtpUser, smtpPass }
  //   resend: { apiKey }
  //   sendgrid: { apiKey }
  //   ses:    { accessKeyId, secretAccessKey, region } (SDK mode) OR smtpHost+smtpUser+smtpPass (SMTP mode)
  //   mailgun: { apiKey, domain, region }
  //   postmark: { serverToken }
  //   brevo:   { apiKey }
  configJson          String   @default("{}")
  fromName            String
  fromEmail           String
  replyTo             String?
  // Usage classification — lets the platform route transactional vs marketing to different providers
  usageType           String   @default("both")  // transactional, marketing, both
  isDefaultTransactional Boolean @default(false)
  isDefaultMarketing  Boolean  @default(false)
  // Platform email (you pay) vs customer's own provider (customer pays)
  isPlatform          Boolean  @default(false)
  status              String   @default("active")  // active, paused, error
  lastTestAt          DateTime?
  lastTestStatus      String?  // success, failed
  lastTestError       String?
  // Stats
  totalSent           Int      @default(0)
  totalDelivered      Int      @default(0)
  totalFailed         Int      @default(0)
  lastUsedAt          DateTime?
  tenantId            String
  workspaceId         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
  @@index([providerType])
  @@index([usageType])
  @@index([isDefaultTransactional])
  @@index([isDefaultMarketing])
}

// ==========================================
// EMAIL TEMPLATES — Reusable transactional + marketing templates
// Built-in slugs: portal-invitation, employee-invitation, password-reset,
//   booking-confirmation, invoice-email, job-assigned, job-completed,
//   payment-receipt, review-request, lead-welcome, lead-followup, campaign-email
// ==========================================

model EmailTemplate {
  id              String   @id @default(cuid())
  name            String   // "Portal Invitation", "Employee Invitation"
  slug            String   // "portal-invitation" (used for programmatic lookup)
  category        String   @default("transactional")  // transactional, marketing, system
  description     String?
  subject         String   // supports {{name}}, {{link}}, {{code}}, etc.
  htmlBody        String   // HTML content with variables
  textBody        String?  // optional plaintext fallback
  // Declared variables for editor assistance
  // [{ "key": "name", "label": "Recipient Name", "required": true, "example": "John" }]
  variablesJson   String   @default("[]")
  isBuiltIn       Boolean  @default(false)  // seed templates cannot be deleted (only edited)
  isDefault       Boolean  @default(false)
  // null tenantId = global platform template (visible to all tenants)
  tenantId        String?
  workspaceId     String?
  // --- Template Studio extensions ---
  language        String   @default("en")  // en, es, hi, ar, etc.
  status          String   @default("published")  // draft, published
  isFavorite      Boolean  @default(false)
  tagsJson        String   @default("[]")  // ["booking","invoice"]
  attachmentsJson String   @default("[]")  // [{name, url, size}]
  brandKitId      String?  // link to BrandKit (null = use tenant default)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([category])
  @@index([slug])
  @@index([status])
}

// ==========================================
// TRIGGER EXECUTION LOG
// ==========================================

model TriggerExecution {
  id              String   @id @default(cuid())
  automationId    String   // FK to WorkflowAutomation
  triggerEvent    String   // The event that fired (e.g., lead.created)
  triggerPayload  String   @default("{}") // JSON payload of the trigger event
  conditionsMet   Boolean  @default(true) // Were conditions satisfied?
  actionsResultsJson String @default("[]") // Results of each action execution
  status          String   @default("success") // success, failed, partial
  error           String?
  durationMs      Int?
  tenantId        String?
  createdAt       DateTime @default(now())

  automation WorkflowAutomation? @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([triggerEvent])
  @@index([status])
  @@index([tenantId])
  @@index([createdAt])
}

// ==========================================
// SUPERADMIN MANAGEMENT
// ==========================================

// Controls which menu items are visible per tenant
model MenuItemConfig {
  id          String   @id @default(cuid())
  tenantId    String   // Use GLOBAL_TENANT_ID constant for global configs
  menuKey     String   // ViewType key e.g., "dashboard", "leads", "inbox", "campaigns"
  enabled     Boolean  @default(true)
  label       String?  // Custom label override (optional)
  icon        String?  // Custom icon override (optional)
  sortOrder   Int      @default(0)
  section     String?  // Section grouping: "Operations", "People", "Marketing", etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, menuKey])
  @@index([tenantId])
  @@index([menuKey])
  @@index([enabled])
}

// Feature flags for granular feature control per tenant
model FeatureFlag {
  id          String   @id @default(cuid())
  tenantId    String
  featureKey  String   // e.g., "whatsapp_crm", "ai_assistant", "campaigns", "workflows"
  enabled     Boolean  @default(true)
  configJson  String   @default("{}")  // Feature-specific configuration
  description String?  // Human-readable description of the feature
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@index([tenantId])
  @@index([featureKey])
  @@index([enabled])
}

