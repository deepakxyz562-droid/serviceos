generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// ==========================================
// MULTI-TENANT CORE
// ==========================================

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  industry          String?
  logo              String?
  phone             String?
  email             String?
  address           String?
  country           String   @default("US")
  currency          String   @default("USD")
  whatsappPhone     String?
  whatsappConfigJson String @default("{}")
  plan              String   @default("starter")
  planStatus        String   @default("trial")
  trialEndsAt       DateTime?
  planStartedAt     DateTime?
  planEndsAt        DateTime?
  settingsJson      String   @default("{}")
  onboardingCompleted Boolean @default(false)
  onboardingStep    Int      @default(0)
  suspendedAt       DateTime?
  suspensionReason  String?
  whiteLabelJson    String   @default("{}")
  region            String   @default("us-east-1")
  mrr               Float    @default(0)
  arr               Float    @default(0)
  churnRate         Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users           User[]
  workspaces      Workspace[]
  leads           Lead[]
  invoices        Invoice[]
  recurringInvoices RecurringInvoice[]
  subscriptions   Subscription[]
  services        Service[]
  reviews         Review[]
  notifications   Notification[]
  quotes          Quote[]
  notificationLogs NotificationLog[]
  conversations   Conversation[]
  forms           Form[]
  workflowAutomations WorkflowAutomation[]
  menuItemConfigs   MenuItemConfig[]
  featureFlags      FeatureFlag[]
  invitations       Invitation[]
  subscriptionPayments SubscriptionPayment[]
  billingEvents     BillingEvent[]
  // Integrations Hub — ads lead capture
  integrationConnections HubIntegrationConnection[]
  metaLeadConfig    MetaLeadConfig?
  metaLeads         MetaLead[]
  googleAdsLeadConfig GoogleAdsLeadConfig?
  googleAdsLeads    GoogleAdsLead[]

  @@index([slug])
  @@index([plan])
  @@index([planStatus])
}

model Subscription {
  id                      String   @id @default(cuid())
  tenantId                String
  plan                    String
  status                  String   @default("trial")  // trial, active, paused, cancelled, expired
  amount                  Float    @default(0)
  currency                String   @default("USD")
  billingCycle            String   @default("monthly")
  startDate               DateTime @default(now())
  endDate                 DateTime?
  trialEndsAt             DateTime?
  paypalSubscriptionId    String?
  paypalPlanId            String?
  paypalOrderId           String?
  paypalPayerEmail        String?
  paymentProvider         String   @default("none")
  maxUsers                Int      @default(1)
  maxJobs                 Int      @default(100)
  maxWorkflows            Int      @default(10)
  featuresJson            String   @default("{}")
  pausedAt                DateTime?
  pauseReason             String?
  pausedById              String?
  // ── Downgrade scheduling (Phase 3) ────────────────────────────────────
  // When a user downgrades mid-cycle, we record the requested lower plan and
  // the date it should take effect (= next renewal date). Applied by the
  // renewal cron on the renewal date. Null when no downgrade is pending.
  pendingDowngradePlan    String?  // starter | growth | pro
  pendingDowngradeAt      DateTime? // when to apply (= current endDate)
  pendingDowngradeCycle   String?  // monthly | yearly (cycle for the downgraded plan)
  // ── Proration tracking (Phase 3) ──────────────────────────────────────
  // When a user upgrades mid-cycle, the prorated charge is recorded here so
  // the receipt + audit log can reference it.
  lastProrationAmount     Float    @default(0)
  lastProrationAt         DateTime?
  seatCount               Int      @default(1)
  aiQuota                 Int      @default(100)
  whatsappQuota           Int      @default(1000)
  emailQuota              Int      @default(5000)
  smsQuota                Int      @default(500)
  storageQuotaMb          Int      @default(1024)
  aiUsageCount            Int      @default(0)
  whatsappUsageCount      Int      @default(0)
  emailUsageCount         Int      @default(0)
  smsUsageCount           Int      @default(0)
  storageUsageMb          Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments SubscriptionPayment[]
  billingEvents BillingEvent[]

  @@index([tenantId])
  @@index([status])
}

// Records each successful subscription payment (PayPal capture, manual, etc.)
// Powers the real Billing History shown in Settings → Billing tab and the
// sidebar Subscription page (replaces the previously-hardcoded FALLBACK_DATA).
model SubscriptionPayment {
  id              String   @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  invoiceNumber   String?  @unique                       // human-readable, e.g. SUB-2025-0001
  amount          Float    @default(0)
  currency        String   @default("USD")
  status          String   @default("paid")              // paid | pending | failed | refunded
  description     String?
  plan            String                                   // starter | growth | pro | enterprise
  billingCycle    String   @default("monthly")           // monthly | yearly
  paymentProvider String   @default("paypal")            // paypal | manual | stripe
  paypalOrderId   String?
  paypalCaptureId String?
  payerEmail      String?
  paidAt          DateTime @default(now())
  refundAmount    Float    @default(0)
  refundedAt      DateTime?
  createdAt       DateTime @default(now())

  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([status])
  @@index([paidAt])
  @@index([paypalOrderId])
  @@index([plan])
}

// ==========================================
// BILLING EVENT AUDIT LOG
// ==========================================
// Append-only audit trail of every billing-related event for a tenant:
// PayPal captures, refunds, cancellations, failures, trial reminders sent,
// trial expirations, plan changes, proration charges, etc.
// One row per event — never updated or deleted (regulatory + dispute defense).
model BillingEvent {
  id              String   @id @default(cuid())
  tenantId        String
  subscriptionId  String?
  type            String   // capture | refund | cancel | fail | trial_reminder | trial_expired | plan_change | proration | downgrade_scheduled | renewal | payment_method_added
  amount          Float    @default(0)
  currency        String   @default("USD")
  status          String   @default("success") // success | failed | pending
  description     String?
  // Raw provider response (PayPal API JSON, etc.) — capped at a reasonable size.
  providerResponse String  @default("{}")
  paymentProvider String   @default("paypal") // paypal | stripe | manual
  paypalOrderId   String?
  paypalCaptureId String?
  payerEmail      String?
  invoiceNumber   String?
  metadata        String   @default("{}") // arbitrary JSON: { plan, billingCycle, daysRemaining, ... }
  createdAt       DateTime @default(now())

  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([paypalOrderId])
}

// ==========================================
// PLAN CATALOG (DB-backed, editable by super-admin)
// ==========================================
// Replaces the hardcoded PLANS in billing-view.tsx + PAYPAL_PLANS in paypal.ts.
// Super-admin can edit pricing, limits, and feature flags without code changes.
// Seeded on first run by /api/plans/seed (idempotent).
model Plan {
  id              String   @id @default(cuid())
  code            String   @unique // starter | growth | pro | enterprise
  name            String
  description     String?
  monthlyPrice    Float    @default(0)
  yearlyPrice     Float    @default(0)
  currency        String   @default("USD")
  maxUsers        Int      @default(1)
  maxJobs         Int      @default(100)
  maxWorkflows    Int      @default(10)
  aiQuota         Int      @default(100)
  whatsappQuota   Int      @default(1000)
  emailQuota      Int      @default(5000)
  smsQuota        Int      @default(500)
  storageQuotaMb  Int      @default(1024)
  featuresJson    String   @default("{}") // { whatsappIntegration, customWorkflows, apiAccess, prioritySupport, ... }
  popular         Boolean  @default(false)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  avatar          String?
  role            String   @default("owner")
  authProvider    String   @default("email")
  authProviderId  String?
  phone           String?
  isActive        Boolean  @default(true)
  isSuperAdmin    Boolean  @default(false)
  lastLoginAt     DateTime?
  mfaEnabled      Boolean  @default(false)
  lastActivityAt  DateTime?
  loginCount      Int      @default(0)
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id])
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  workflows    Workflow[]  @relation("WorkflowCreator")
  credentials  Credential[] @relation("CredentialOwner")
  notifications Notification[]
  employeeAccount Employee?
  employeeStatusLogs EmployeeStatusLog[]
  sentInvitations  Invitation[] @relation("InvitationInvitedBy")

  @@index([email])
  @@index([tenantId])
}

// ==========================================
// SERVICE CATALOG
// ==========================================

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   @default("general")
  basePrice   Float    @default(0)
  duration    Int      @default(60)
  icon        String?
  isActive    Boolean  @default(true)
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
}

// ==========================================
// LEAD MANAGEMENT
// ==========================================

model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String   @default("manual")
  status          String   @default("new")
  priority        String   @default("medium")
  value           Float    @default(0)
  description     String?
  address         String?
  serviceType     String?
  serviceId       String?
  assignedToId    String?
  tenantId        String?
  customerId      String?
  jobId           String?  @unique
  notesJson       String   @default("[]")
  tagsJson        String   @default("[]")
  followUpAt      DateTime?
  convertedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  job        Job?      @relation(fields: [jobId], references: [id])
  assignedTo Employee? @relation(fields: [assignedToId], references: [id])
  conversation Conversation?
  journey      CustomerJourney?

  @@index([tenantId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// ==========================================
// INVOICES
// ==========================================

model Invoice {
  id          String    @id @default(cuid())
  number      String    @unique
  tenantId    String?
  jobId       String?
  bookingId   String?
  customerId  String?
  employeeId  String?
  amount      Float     @default(0)
  tax         Float     @default(0)
  discount    Float     @default(0)
  total       Float     @default(0)
  currency    String    @default("USD")      // Transaction currency (what the customer sees/pays)
  exchangeRate Float    @default(1)           // Rate at creation: 1 base = X transaction currency
  baseCurrency String   @default("USD")      // Tenant base currency at creation time
  baseAmount   Float    @default(0)           // Amount converted to base currency (for reporting)
  status      String    @default("draft")     // draft, sent, paid, pending_approval, cancelled
  invoiceType String    @default("standard")  // standard, job_completion, deposit, milestone, recurring
  milestoneIndex Int?                        // 1-based index for milestone invoices (1=30%, 2=40%, 3=30%)
  parentInvoiceId String?                    // For milestone splits → the originating job's first invoice
  recurrenceId String?                       // FK to RecurringInvoice schedule that generated this (recurring type)
  dueDate     DateTime?
  sentAt      DateTime?
  paidAt      DateTime?
  itemsJson   String    @default("[]")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant?          @relation(fields: [tenantId], references: [id])
  job       Job?             @relation(fields: [jobId], references: [id])
  customer  Customer?        @relation(fields: [customerId], references: [id])
  employee  Employee?        @relation(fields: [employeeId], references: [id])
  booking   Booking?         @relation("BookingInvoices", fields: [bookingId], references: [id])
  recurrence RecurringInvoice? @relation(fields: [recurrenceId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
  @@index([invoiceType])
  @@index([bookingId])
  @@index([recurrenceId])
  @@index([parentInvoiceId])
}

// Recurring invoice schedule (AMC / subscriptions / monthly maintenance contracts)
model RecurringInvoice {
  id              String   @id @default(cuid())
  name            String                              // e.g. "Monthly Pool Cleaning — John Doe"
  tenantId        String?
  customerId      String?
  jobId           String?                             // optional template job
  frequency       String   @default("monthly")        // weekly, monthly, quarterly, yearly
  dayOfMonth      Int      @default(1)                 // 1-31 (for monthly+); day of week for weekly (0-6)
  amount          Float    @default(0)                 // recurring charge (subtotal, before tax)
  taxPercent      Float    @default(0)
  currency        String   @default("USD")
  itemsJson       String   @default("[]")              // line items template
  notes           String?
  startDate       DateTime @default(now())
  endDate         DateTime?                            // null = open-ended
  nextRunAt       DateTime @default(now())             // when the next invoice should be generated
  lastRunAt       DateTime?
  lastInvoiceId   String?
  active          Boolean  @default(true)
  executionCount  Int      @default(0)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant   Tenant?    @relation(fields: [tenantId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])
  job      Job?       @relation("JobRecurringInvoices", fields: [jobId], references: [id])
  invoices Invoice[]

  @@index([tenantId])
  @@index([customerId])
  @@index([active])
  @@index([nextRunAt])
}

// ==========================================
// REVIEWS
// ==========================================

model Review {
  id          String   @id @default(cuid())
  rating      Int      @default(5)
  comment     String?
  jobId       String?  @unique
  customerId  String?
  employeeId  String?
  tenantId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([rating])
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  userId    String?
  tenantId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([read])
}

// ==========================================
// QUOTES
// ==========================================

model Quote {
  id            String    @id @default(cuid())
  title         String
  description   String?
  itemsJson     String    @default("[]")  // Service line items with serviceId, name, price, qty
  addOnsJson    String    @default("[]")  // Add-on items with name, price
  subtotal      Float     @default(0)
  tax           Float     @default(0)
  taxRate       Float     @default(0)     // Tax percentage
  discount      Float     @default(0)
  discountType  String    @default("fixed") // fixed, percentage
  total         Float     @default(0)
  currency      String    @default("USD")      // Transaction currency
  exchangeRate  Float     @default(1)           // Rate at creation: 1 base = X transaction currency
  baseCurrency  String    @default("USD")      // Tenant base currency at creation time
  baseAmount    Float     @default(0)           // Amount converted to base currency (for reporting)
  status        String    @default("draft") // draft, sent, accepted, rejected, expired
  tenantId      String?
  customerId    String?
  leadId        String?
  validUntil    DateTime?
  whatsappSent  Boolean   @default(false)
  whatsappSentAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
}

// ==========================================
// FORM BUILDER
// ==========================================

model Form {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  type                String   @default("lead_capture") // lead_capture, booking, feedback, survey, quote_request, job_request, custom
  status              String   @default("active") // active, inactive, archived
  fieldsJson          String   @default("[]")     // Array of form field definitions
  submissionActions   String   @default("[]")     // Array of actions: create_lead, create_customer, create_booking, create_job, create_quote, store_response, send_whatsapp, send_email, trigger_workflow, call_webhook
  fieldMappingJson    String   @default("{}")     // Form field → CRM field mapping
  welcomeMessage      String   @default("")
  completionMessage   String   @default("")
  whatsappOwnerTemplate String  @default("")     // WhatsApp template sent to owner on submission
  whatsappUserTemplate  String  @default("")     // WhatsApp template sent to user on submission
  whatsappAiGenerated  Boolean @default(false)   // AI-generate user WhatsApp confirmation
  embedScriptEnabled  Boolean  @default(false)
  embedIframeEnabled  Boolean  @default(false)
  slug                String?  @unique           // For embed URLs
  submissions         Int      @default(0)
  conversionRate      Float    @default(0)
  tenantId            String?
  workspaceId         String?
  createdById         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  responses FormResponse[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([slug])
}

model FormResponse {
  id          String   @id @default(cuid())
  formId      String
  dataJson    String   @default("{}")  // Key-value pairs of form responses
  respondent  String?  // Phone or email of submitter
  respondentName String?
  source      String   @default("direct") // direct, whatsapp, embed, wordpress, webhook
  leadId      String?  // If a lead was created from this response
  customerId  String?  // If a customer was created
  jobId       String?  // If a job was created
  quoteId     String?  // If a quote was created
  bookingId   String?  // If a booking was created
  actionsResultsJson String @default("{}") // Results of submission actions
  tenantId    String?
  createdAt   DateTime @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([source])
  @@index([tenantId])
  @@index([createdAt])
}

// ==========================================
// WORKFLOW AUTOMATION (Enhanced)
// ==========================================

model WorkflowAutomation {
  id            String   @id @default(cuid())
  name          String
  description   String?
  triggerType   String   // lead.created, lead.assigned, lead.status_changed, lead.converted, customer.created, quote.sent, quote.accepted, quote.rejected, booking.created, booking.confirmed, booking.cancelled, job.created, job.assigned, job.completed, job.cancelled, employee.assigned, whatsapp.message_received, form.submitted, invoice.created, invoice.paid, invoice.overdue, time.based
  triggerConfigJson String @default("{}") // Trigger-specific config (e.g., time delays, field filters)
  conditionsJson String  @default("[]")   // Array of condition objects { field, operator, value }
  actionsJson   String   @default("[]")   // Array of action objects { type, config }
  active        Boolean  @default(true)
  executionCount Int     @default(0)
  lastExecutedAt DateTime?
  lastExecutionStatus String? // success, failed
  tagsJson      String   @default("[]")
  tenantId      String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  executions TriggerExecution[]

  @@index([tenantId])
  @@index([triggerType])
  @@index([active])
}

// ==========================================
// WORKFLOW AUTOMATION
// ==========================================

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  industry      String?
  logo          String?
  plan          String   @default("free")
  planExpiresAt DateTime?
  ownerId       String
  tenantId      String?
  settingsJson  String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  users         User[]
  workflows     Workflow[]
  credentials   Credential[]
  variables     Variable[]
  employees     Employee[]
  customers     Customer[]
  resources     Resource[]
  jobs          Job[]
  contactLists  ContactList[]
  folders       Folder[]
  webhookSources WebhookSource[]
  invitations   Invitation[]

  @@index([tenantId])
}

model Workflow {
  id            String   @id @default(cuid())
  name          String
  description   String?
  nodesJson     String   @default("[]")
  edgesJson     String   @default("[]")
  settingsJson  String   @default("{}")
  active        Boolean  @default(false)
  tags          String   @default("[]")
  folderId      String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  createdBy    User?         @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  versions     WorkflowVersion[]
  executions   Execution[]
  webhooks     WebhookRegistration[]
  folder       Folder?       @relation(fields: [folderId], references: [id])

  @@index([workspaceId])
  @@index([active])
}

model WorkflowVersion {
  id           String   @id @default(cuid())
  workflowId   String
  snapshotJson String
  message      String?
  createdById  String?
  createdAt    DateTime @default(now())
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Credential {
  id            String   @id @default(cuid())
  name          String
  type          String
  encryptedData String
  workspaceId   String?
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace              Workspace?             @relation(fields: [workspaceId], references: [id])
  user                   User?                  @relation("CredentialOwner", fields: [userId], references: [id], onDelete: SetNull)
  communicationProviders CommunicationProvider[]

  @@index([workspaceId])
}

model Execution {
  id           String    @id @default(cuid())
  workflowId   String
  status       String    @default("running")
  mode         String    @default("manual")
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  dataJson     String    @default("{}")
  errorJson    String?
  durationMs   Int?
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeData     ExecutionNodeData[]

  @@index([workflowId])
  @@index([status])
}

model ExecutionNodeData {
  id          String   @id @default(cuid())
  executionId String
  nodeName    String
  nodeId      String
  inputJson   String   @default("[]")
  outputJson  String   @default("[]")
  errorJson   String?
  durationMs  Int?
  status      String   @default("success")
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model WebhookRegistration {
  id          String   @id @default(cuid())
  workflowId  String
  path        String
  method      String   @default("POST")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([path])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  metadataJson String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

