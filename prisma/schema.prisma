generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// MULTI-TENANT CORE
// ==========================================

model Tenant {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  industry          String?
  logo              String?
  phone             String?
  email             String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  country           String   @default("US")
  currency          String   @default("USD")
  whatsappPhone     String?
  whatsappConfigJson String @default("{}")
  plan              String   @default("starter")
  planStatus        String   @default("trial")
  trialEndsAt       DateTime?
  planStartedAt     DateTime?
  planEndsAt        DateTime?
  settingsJson      String   @default("{}")
  featureFlagsJson  String   @default("{}")
  subdomain         String?  @unique
  customDomain      String?  @unique
  subdomainVerified Boolean  @default(false)
  customDomainVerified Boolean @default(false)
  customDomainDnsJson String @default("{}")
  onboardingCompleted Boolean @default(false)
  onboardingStep    Int      @default(0)
  suspendedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users           User[]
  workspaces      Workspace[]
  leads           Lead[]
  invoices        Invoice[]
  subscriptions   Subscription[]
  services        Service[]
  reviews         Review[]
  notifications   Notification[]
  quotes          Quote[]
  notificationLogs NotificationLog[]
  conversations   Conversation[]
  invitations     Invitation[]
  customDomains   CustomDomain[]
  bookings        Booking[]
  knowledgeArticles KnowledgeArticle[]
  documents       Document[]
  leadDiscoveries LeadDiscovery[]
  discoverySearches LeadDiscoverySearch[]

  @@index([slug])
  @@index([plan])
}

model Subscription {
  id                      String   @id @default(cuid())
  tenantId                String
  plan                    String
  status                  String   @default("trial")
  amount                  Float    @default(0)
  currency                String   @default("USD")
  billingCycle            String   @default("monthly")
  startDate               DateTime @default(now())
  endDate                 DateTime?
  trialEndsAt             DateTime?
  paypalSubscriptionId    String?
  paypalPlanId            String?
  paypalOrderId           String?
  paypalPayerEmail        String?
  paymentProvider         String   @default("none")
  maxUsers                Int      @default(1)
  maxJobs                 Int      @default(100)
  maxWorkflows            Int      @default(10)
  featuresJson            String   @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model Invitation {
  id              String    @id @default(cuid())
  token           String    @unique
  email           String
  name            String?
  role            String    @default("technician")
  phone           String?
  status          String    @default("pending")  // pending, accepted, expired, cancelled
  message         String?
  invitedById     String?
  tenantId        String
  workspaceId     String?
  employeeId      String?   @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  invitedBy  User?      @relation("SentInvitations", fields: [invitedById], references: [id])
  employee   Employee?  @relation(fields: [employeeId], references: [id])

  @@index([token])
  @@index([email])
  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
}

model CustomDomain {
  id              String   @id @default(cuid())
  domain          String   @unique
  tenantId        String
  verified        Boolean  @default(false)
  verificationToken String?
  dnsRecordsJson  String   @default("{}")
  sslStatus       String   @default("pending")  // pending, active, error
  active          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([domain])
  @@index([tenantId])
  @@index([active])
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  passwordHash    String?
  avatar          String?
  role            String   @default("owner")
  isSuperAdmin    Boolean  @default(false)
  authProvider    String   @default("email")
  authProviderId  String?
  phone           String?
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  tenantId        String?
  workspaceId     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id])
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  workflows    Workflow[]  @relation("WorkflowCreator")
  credentials  Credential[] @relation("CredentialOwner")
  notifications Notification[]
  employeeAccount Employee?
  employeeStatusLogs EmployeeStatusLog[]
  sentInvitations Invitation[] @relation("SentInvitations")

  @@index([email])
  @@index([tenantId])
}

// ==========================================
// SERVICE CATALOG
// ==========================================

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  category        String   @default("general")
  basePrice       Float    @default(0)
  duration        Int      @default(60)
  icon            String?
  isActive        Boolean  @default(true)
  tenantId        String?
  // ─── Service Catalog enhancements ───
  assignedTeamJson String   @default("[]")  // employee IDs assigned to this service
  addOnsJson       String   @default("[]")  // add-on service definitions
  upsellServiceIdsJson String @default("[]")  // IDs of upsell services
  imageUrl         String?
  tagsJson         String   @default("[]")
  sortOrder        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

// ==========================================
// LEAD MANAGEMENT
// ==========================================

model Lead {
  id              String   @id @default(cuid())
  name            String
  phone           String
  email           String?
  source          String   @default("manual")
  status          String   @default("new")
  priority        String   @default("medium")
  value           Float    @default(0)
  description     String?
  address         String?
  serviceType     String?
  serviceId       String?
  assignedToId    String?
  tenantId        String?
  customerId      String?
  jobId           String?  @unique
  notesJson       String   @default("[]")
  tagsJson        String   @default("[]")
  followUpAt      DateTime?
  convertedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant?   @relation(fields: [tenantId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  job        Job?      @relation(fields: [jobId], references: [id])
  assignedTo Employee? @relation(fields: [assignedToId], references: [id])
  conversation Conversation?
  journey      CustomerJourney?

  @@index([tenantId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// ==========================================
// INVOICES
// ==========================================

model Invoice {
  id          String    @id @default(cuid())
  number      String    @unique
  tenantId    String?
  jobId       String?
  customerId  String?
  employeeId  String?
  amount      Float     @default(0)
  tax         Float     @default(0)
  discount    Float     @default(0)
  total       Float     @default(0)
  currency    String    @default("USD")
  status      String    @default("draft")
  dueDate     DateTime?
  paidAt      DateTime?
  itemsJson   String    @default("[]")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([customerId])
}

// ==========================================
// REVIEWS
// ==========================================

model Review {
  id              String   @id @default(cuid())
  rating          Int      @default(5)
  comment         String?
  jobId           String?  @unique
  customerId      String?
  employeeId      String?
  tenantId        String?
  // ─── Review & Reputation enhancements ───
  source          String   @default("internal")  // internal, google, whatsapp, form
  status          String   @default("published")  // published, pending, flagged
  npsScore        Int?     // Net Promoter Score 0-10
  responseJson    String   @default("{}")  // business response to review
  googleReviewId  String?  // Google review ID if synced
  reviewUrl       String?  // URL to the review
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([rating])
  @@index([source])
  @@index([status])
}

// ==========================================
// NOTIFICATIONS
// ==========================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  userId    String?
  tenantId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
  @@index([read])
}

// ==========================================
// QUOTES
// ==========================================

model Quote {
  id              String    @id @default(cuid())
  title           String
  description     String?
  itemsJson       String    @default("[]")
  subtotal        Float     @default(0)
  tax             Float     @default(0)
  discount        Float     @default(0)
  total           Float     @default(0)
  status          String    @default("draft")  // draft, sent, accepted, rejected, expired, won
  tenantId        String?
  customerId      String?
  leadId          String?
  validUntil      DateTime?
  // ─── Quotes & Estimates enhancements ───
  quoteNumber     String?
  templateName    String    @default("standard")  // standard, detailed, simple
  approvalToken   String?   @unique  // token for customer approval link
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectedReason  String?
  sentVia         String?   // email, whatsapp, link, manual
  sentAt          DateTime?
  version         Int       @default(1)
  parentQuoteId   String?   // for version history
  notesJson       String    @default("[]")  // internal notes
  pdfUrl          String?   // generated PDF URL
  currency        String    @default("USD")
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([leadId])
  @@index([customerId])
  @@index([approvalToken])
}

// ==========================================
// WORKFLOW AUTOMATION
// ==========================================

model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  industry      String?
  logo          String?
  plan          String   @default("free")
  planExpiresAt DateTime?
  ownerId       String
  tenantId      String?
  settingsJson  String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  users         User[]
  workflows     Workflow[]
  credentials   Credential[]
  variables     Variable[]
  employees     Employee[]
  customers     Customer[]
  resources     Resource[]
  jobs          Job[]
  contactLists  ContactList[]
  folders       Folder[]
  webhookSources WebhookSource[]
  invitations    Invitation[]

  @@index([tenantId])
}

model Workflow {
  id            String   @id @default(cuid())
  name          String
  description   String?
  nodesJson     String   @default("[]")
  edgesJson     String   @default("[]")
  settingsJson  String   @default("{}")
  active        Boolean  @default(false)
  tags          String   @default("[]")
  folderId      String?
  workspaceId   String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace?    @relation(fields: [workspaceId], references: [id])
  createdBy    User?         @relation("WorkflowCreator", fields: [createdById], references: [id], onDelete: SetNull)
  versions     WorkflowVersion[]
  executions   Execution[]
  webhooks     WebhookRegistration[]
  folder       Folder?       @relation(fields: [folderId], references: [id])

  @@index([workspaceId])
  @@index([active])
}

model WorkflowVersion {
  id           String   @id @default(cuid())
  workflowId   String
  snapshotJson String
  message      String?
  createdById  String?
  createdAt    DateTime @default(now())
  workflow     Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Credential {
  id            String   @id @default(cuid())
  name          String
  type          String
  encryptedData String
  workspaceId   String?
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  user      User?      @relation("CredentialOwner", fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

model Execution {
  id           String    @id @default(cuid())
  workflowId   String
  status       String    @default("running")
  mode         String    @default("manual")
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  dataJson     String    @default("{}")
  errorJson    String?
  durationMs   Int?
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeData     ExecutionNodeData[]

  @@index([workflowId])
  @@index([status])
}

model ExecutionNodeData {
  id          String   @id @default(cuid())
  executionId String
  nodeName    String
  nodeId      String
  inputJson   String   @default("[]")
  outputJson  String   @default("[]")
  errorJson   String?
  durationMs  Int?
  status      String   @default("success")
  execution   Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model WebhookRegistration {
  id          String   @id @default(cuid())
  workflowId  String
  path        String
  method      String   @default("POST")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([path])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  metadataJson String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  keyHash   String
  name      String
  scopes    String   @default("[]")
  lastUsed  DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@unique([keyHash])
}

model Variable {
  id             String   @id @default(cuid())
  key            String
  valueEncrypted String
  workspaceId    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  workspace      Workspace? @relation(fields: [workspaceId], references: [id])

  @@unique([key, workspaceId])
}

model Folder {
  id          String   @id @default(cuid())
  name        String
  parentId    String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  workflows   Workflow[]
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    Folder[] @relation("FolderHierarchy")

  @@index([workspaceId])
}

model Template {
  id           String   @id @default(cuid())
  name         String
  description  String?
  workflowJson String
  category     String
  icon         String?
  featured     Boolean  @default(false)
  usageCount   Int      @default(0)
  rating       Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
}

// ==========================================
// BUSINESS OPERATIONS
// ==========================================

model Employee {
  id              String    @id @default(cuid())
  name            String
  phone           String
  email           String?
  role            String    @default("technician")
  skills          String    @default("[]")
  status          String    @default("available")
  avatar          String?
  whatsappId      String?
  rating          Float     @default(0)
  completedJobs   Int       @default(0)
  location        String?
  latitude        Float?
  longitude       Float?
  workspaceId     String?
  lastSeenAt      DateTime?
  currentJobId    String?   @unique
  userId          String?   @unique
  lastLocationAt  DateTime?
  onLeaveUntil    DateTime?
  // ─── Workforce Management enhancements ───
  serviceAreas    String    @default("[]")  // JSON array of service area names/coords
  commissionRate  Float     @default(0)     // percentage commission
  commissionJson  String    @default("{}")  // commission tracking data
  attendanceJson  String    @default("{}")  // clock in/out records
  performanceScore Float    @default(0)     // computed performance metric
  employeeCode    String?   // short code for scheduling
  branchId        String?   // branch assignment
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace?              @relation(fields: [workspaceId], references: [id])
  assignedJobs    Job[]                   @relation("JobAssignee")
  leads           Lead[]
  invoices        Invoice[]
  currentJob      Job?                    @relation("EmployeeCurrentJob", fields: [currentJobId], references: [id])
  userAccount     User?                   @relation(fields: [userId], references: [id])
  statusLogs      EmployeeStatusLog[]
  notificationLogs NotificationLog[]
  invitation      Invitation?
  collectedPayments Job[] @relation("JobPaymentCollector")
  bookings        Booking[]

  @@index([role])
  @@index([status])
  @@index([workspaceId])
  @@index([lastSeenAt])
  @@index([currentJobId])
  @@index([userId])
}

model EmployeeStatusLog {
  id           String   @id @default(cuid())
  employeeId   String
  fromStatus   String?
  toStatus     String
  reason       String?
  changedById  String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  changedBy User?   @relation(fields: [changedById], references: [id])

  @@index([employeeId])
  @@index([toStatus])
  @@index([createdAt])
}

model NotificationLog {
  id            String   @id @default(cuid())
  type          String   @default("whatsapp")  // whatsapp, email, sms, push, in_app
  recipient     String
  recipientName String?
  recipientRole String?  // employee, customer, manager
  subject       String?
  message       String
  status        String   @default("sent")  // sent, delivered, read, failed
  externalId    String?  // WhatsApp message ID, email message ID, etc.
  jobId         String?
  employeeId    String?
  customerId    String?
  tenantId      String?
  metadataJson  String   @default("{}")
  createdAt     DateTime @default(now())

  job      Job?      @relation(fields: [jobId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([type])
  @@index([status])
  @@index([jobId])
  @@index([employeeId])
  @@index([customerId])
  @@index([createdAt])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  address     String?
  whatsappId  String?
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  jobs      Job[]
  invoices  Invoice[]
  leads     Lead[]
  notificationLogs NotificationLog[]
  conversations        Conversation[]
  journeys             CustomerJourney[]
  portalSessions       CustomerPortalSession[]

  @@index([phone])
  @@index([workspaceId])
}

model Resource {
  id            String   @id @default(cuid())
  name          String
  phone         String
  type          String   @default("driver")
  status        String   @default("available")
  skills        String   @default("[]")
  location      String?
  avatar        String?
  whatsappId    String?
  rating        Float    @default(0)
  completedJobs Int      @default(0)
  metadataJson  String?
  workspaceId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace    Workspace? @relation(fields: [workspaceId], references: [id])
  assignedJobs Job[]      @relation("JobResource")

  @@index([type])
  @@index([status])
}

model Job {
  id                 String    @id @default(cuid())
  jobNumber          String?
  title              String
  description        String?
  status             String    @default("pending")
  priority           String    @default("medium")
  type               String    @default("service")
  address            String?
  pickup             String?
  dropoff            String?
  scheduledAt        DateTime?
  scheduledTime      String?
  estimatedDuration  Int?
  actualStartTime    DateTime?
  actualEndTime      DateTime?
  notes              String?
  customerId         String?
  customerName       String?
  customerPhone      String?
  assigneeId         String?
  assigneeName       String?
  assigneePhone      String?
  resourceId         String?
  serviceId          String?
  checkInLat         Float?
  checkInLng         Float?
  checkOutLat        Float?
  checkOutLng        Float?
  customerRating     Int?
  employeeRating     Int?
  externalId         String?
  externalSource     String?
  whatsappMessageId  String?
  whatsappSessionId  String?
  assignmentStatus   String?
  notificationLogJson String @default("[]")
  workspaceId        String?
  // ─── Payment & COD fields ───
  paymentMethod      String?   // cod, online, card, bank_transfer, upi, null
  paymentStatus      String    @default("pending") // pending, collected, waived, failed
  amountCollected    Float?
  collectedAt        DateTime?
  collectedById      String?
  // ─── Completion proof fields ───
  completionNotes    String?   // Employee notes at job completion
  completionPhotosJson String @default("[]") // Array of photo URLs/base64
  completionSignatureData String? // Base64 signature image
  completedAt        DateTime? // When the employee marked the job complete with proof
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  assignee   Employee?  @relation("JobAssignee", fields: [assigneeId], references: [id])
  customer   Customer?  @relation(fields: [customerId], references: [id])
  resource   Resource?  @relation("JobResource", fields: [resourceId], references: [id])
  lead       Lead?
  invoices   Invoice[]
  currentEmployee Employee? @relation("EmployeeCurrentJob")
  notificationLogs NotificationLog[]
  conversation      Conversation?
  journey           CustomerJourney?
  collectedBy       Employee? @relation("JobPaymentCollector", fields: [collectedById], references: [id])

  @@index([status])
  @@index([assigneeId])
  @@index([customerId])
  @@index([scheduledAt])
  @@index([workspaceId])
  @@index([paymentStatus])
  @@index([paymentMethod])
}

model ContactList {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("custom")
  roleFilter  String?
  icon        String?
  color       String?
  isDefault   Boolean  @default(false)
  workspaceId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  entries   ContactListEntry[]

  @@index([type])
  @@index([workspaceId])
}

model ContactListEntry {
  id            String   @id @default(cuid())
  contactListId String
  name          String
  phone         String
  email         String?
  role          String?
  employeeId    String?
  customerId    String?
  whatsappId    String?
  avatar        String?
  metadataJson  String?
