// ==========================================
// DOCUMENT CENTER
// ==========================================

model Document {
  id              String   @id @default(cuid())
  name            String
  description     String?
  type            String   @default("general")  // general, contract, invoice, report, proposal, manual, other
  category        String   @default("general")
  fileUrl         String
  fileType        String?  // pdf, doc, xls, png, etc.
  fileSize        Int?     // Size in bytes
  accessLevel     String   @default("admin")    // admin, employee, customer
  customerId      String?
  jobId           String?
  employeeId      String?
  uploadedById    String?
  isShared        Boolean  @default(false)
  sharedWithJson  String   @default("[]")
  tagsJson        String   @default("[]")
  tenantId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  job      Job?      @relation(fields: [jobId], references: [id])
  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([category])
  @@index([accessLevel])
  @@index([uploadedById])
  @@index([createdAt])
}

// ==========================================
// INVITATIONS (Enterprise Portal Access Management)
// ==========================================
// Magic-link invitations for customers to activate their portal account
// and for employees to be onboarded. One Invitation row per outstanding
// invite — token is the lookup key for the activation link.

model Invitation {
  id          String   @id @default(cuid())
  token       String   @unique
  email       String
  name        String?
  role        String                                    // employee | customer
  phone       String?
  status      String   @default("pending")              // pending | accepted | cancelled | expired
  message     String?
  invitedById String?
  tenantId    String?
  workspaceId String?
  employeeId  String?  @unique
  customerId  String?  @unique
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invitedBy  User?      @relation("InvitationInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  tenant     Tenant?    @relation(fields: [tenantId], references: [id])
  workspace  Workspace? @relation(fields: [workspaceId], references: [id])
  employee   Employee?  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([status])
  @@index([tenantId])
  @@index([employeeId])
  @@index([customerId])
  @@index([expiresAt])
}

// ==========================================
// CUSTOMER PAYMENT METHODS
// ==========================================
// Stores tokenized payment methods (card/UPI/bank) for customer self-service.
// We never store raw card numbers — only the mock token + last4.

model PaymentMethod {
  id            String   @id @default(cuid())
  customerId    String
  tenantId      String?
  workspaceId   String?
  type          String   @default("card")  // card | upi | bank
  brand         String?                     // Visa, Mastercard, Amex, RuPay, etc.
  last4         String?
  expMonth      Int?
  expYear       Int?
  holderName    String?
  upiId         String?
  bankName      String?
  isDefault     Boolean  @default(false)
  tokenJson     String   @default("{}")
  metadataJson  String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tenantId])
  @@index([isDefault])
}

// ==========================================
// INTEGRATIONS HUB — ADS LEAD CAPTURE
// ==========================================

// Per-tenant connection state for any integration in the hub
// (Meta Ads, Google Ads, Shopify, Stripe, etc.). Credentials are
// stored in credentialsJson (NEVER returned to the client unmasked).
model HubIntegrationConnection {
  id              String   @id @default(cuid())
  tenantId        String
  integrationKey  String   // meta-ads, google-ads, shopify, ...
  status          String   @default("disconnected") // connected | disconnected | error | syncing
  credentialsJson String   @default("{}")            // encrypted credentials (masked on read)
  configJson      String   @default("{}")            // non-secret config (pageId, formIds, ...)
  connectedAt     DateTime?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, integrationKey])
  @@index([tenantId])
}

// Meta Business Platform (Facebook + Instagram) lead-gen config per tenant.
// Used to verify Meta webhooks and fetch lead details via the Graph API.
model MetaLeadConfig {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  appId               String?
  appSecret           String?
  verifyToken         String?
  pageId              String?
  pageName            String?
  pageAccessToken     String?
  subscriptionVerified Boolean @default(false)
  autoCreateLeads     Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// A lead captured from a Meta (Facebook/Instagram) Lead Gen form webhook.
model MetaLead {
  id                String   @id @default(cuid())
  tenantId          String
  leadgenId         String   // Meta leadgen_id
  formId            String   // Meta form_id
  formName          String?
  pageId            String
  platform          String   @default("facebook") // facebook | instagram
  adId              String?
  adName            String?
  adsetId           String?
  campaignId        String?
  campaignName      String?
  contactName       String?
  email             String?
  phone             String?
  city              String?
  country           String?
  customFieldsJson  String   @default("{}")
  rawDataJson       String   @default("{}")
  leadStatus        String   @default("new") // new | contacted | qualified | converted | lost
  convertedContactId String?
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, leadgenId])
  @@index([tenantId, leadStatus])
  @@index([tenantId, platform])
}

// Google Ads lead-form config per tenant. Used to poll the Google Ads API
// for new lead-form submissions (Google does not push webhooks for lead forms).
model GoogleAdsLeadConfig {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  clientId          String?
  clientSecret      String?
  developerToken    String?
  refreshToken      String?
  loginCustomerId   String?  // manager account id (XXX-XXX-XXXX or raw digits)
  accountName       String?
  autoCreateLeads   Boolean  @default(true)
  lastPollAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// A lead captured from a Google Ads Lead Form extension.
model GoogleAdsLead {
  id                String   @id @default(cuid())
  tenantId          String
  leadId            String   // Google's lead id / resource name
  formId            String?
  formName          String?
  campaignId        String?
  campaignName      String?
  adGroupId         String?
  resourceName      String?
  contactName       String?
  email             String?
  phone             String?
  postalCode        String?
  customFieldsJson  String   @default("{}")
  rawDataJson       String   @default("{}")
  leadStatus        String   @default("new") // new | contacted | qualified | converted | lost
  convertedContactId String?
  submittedAt       DateTime?
  receivedAt        DateTime @default(now())
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, leadId])
  @@index([tenantId, leadStatus])
}

// ==========================================
// TEMPLATE STUDIO — Brand Kit, Image Library, Template Packs
// ==========================================

model BrandKit {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  logoUrl         String?
  primaryColor    String   @default("#0f766e")  // teal-700 default
  secondaryColor  String   @default("#1f2937")  // gray-800
  accentColor     String   @default("#f59e0b")  // amber-500
  fontFamily      String   @default("Inter, sans-serif")
  footerHtml      String?  // custom email footer HTML
  companyName     String?
  address         String?
  website         String?
  email           String?
  phone           String?
  socialLinksJson String   @default("[]")  // [{platform, url}]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ImageLibrary {
  id              String   @id @default(cuid())
  tenantId        String?
  name            String
  url             String   // stored path or external URL
  folder          String   @default("uploaded")  // logos, promotions, service, seasonal, uploaded
  mediaType       String   @default("image/png")  // MIME type
  size            Int      @default(0)  // bytes
  width           Int?
  height          Int?
  uploadedBy      String?  // user id
  createdAt       DateTime @default(now())

  @@index([tenantId, folder])
}

model TemplatePack {
  id              String   @id @default(cuid())
  slug            String   @unique  // "lead-pack", "booking-pack", etc.
  name            String
  description     String?
  category        String   @default("business")  // business, industry
  industry        String?  // plumbing, hvac, electrical, etc.
  icon            String   @default("Package")
  color           String   @default("#0f766e")
  templatesJson   String   @default("[]")  // pack definition: [{channel, name, category, ...}]
  isInstalled     Boolean  @default(false)
  installedBy     String?  // tenantId that installed
  installCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([industry])
}

model TemplateAsset {
  id          String   @id @default(cuid())
  companyId   String   // tenantId / company_id
  bucket      String   // bucket name: template-assets, campaign-assets, etc.
  filePath    String   // company_1/email/logo.png
  fileName    String   // original file name
  mimeType    String   // image/png
  size        Int      @default(0)
  folder      String   @default("general") // email, whatsapp, general
  uploadedBy  String?  // user id
  createdAt   DateTime @default(now())

  @@index([companyId, bucket])
  @@index([companyId, folder])
  @@index([bucket])
}
