# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# When USE_SUPABASE_DB=true, the app uses Supabase REST API (PostgREST)
# and does NOT need DATABASE_URL for runtime queries.
#
# However, DATABASE_URL is still needed for:
#   - Prisma schema migrations (bun run db:push)
#   - Fallback if Supabase REST API is disabled
#
# For local development (SQLite):
DATABASE_URL=file:./db/custom.db
#
# For Neon PostgreSQL:
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
#
# For Supabase PostgreSQL (recommended for production):
# Get your connection string from: Supabase Dashboard → Settings → Database
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# ============================================================
# SUPABASE CONFIGURATION (required when USE_SUPABASE_DB=true)
# ============================================================
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# DATABASE MODE SWITCH
# ============================================================
# true  = Use Supabase REST API (PostgREST) — no direct SQL connections
# false = Use Prisma with DATABASE_URL for direct SQL connections
USE_SUPABASE_DB=false

# ============================================================
# GOOGLE OAUTH
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ============================================================
# JWT SECRET
# ============================================================
JWT_SECRET=your-production-jwt-secret

# ============================================================
# PAYPAL
# ============================================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret
PAYPAL_MERCHANT_EMAIL=your_paypal_email@example.com
PAYPAL_SANDBOX=true

# ============================================================
# WHATSAPP (optional)
# ============================================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=flowforge_verify_token

# ============================================================
# APP URL (for webhook callbacks)
# ============================================================
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ============================================================
# NETLIFY DEPLOYMENT CHECKLIST
# ============================================================
# When deploying to Netlify, ensure ALL these env vars are set
# in Netlify Dashboard → Site settings → Environment variables:
#
# 1. DATABASE_URL          → Supabase PostgreSQL connection string
# 2. DIRECT_URL            → Same as above (for Prisma)
# 3. USE_SUPABASE_DB       → true
# 4. NEXT_PUBLIC_SUPABASE_URL → https://your-project.supabase.co
# 5. SUPABASE_SERVICE_ROLE_KEY → eyJ... (server-side, no NEXT_PUBLIC_ prefix!)
# 6. SUPABASE_ANON_KEY     → eyJ...
# 7. JWT_SECRET            → your-production-secret
#
# IMPORTANT: After changing env vars on Netlify, you MUST
# trigger a new deploy for changes to take effect.
