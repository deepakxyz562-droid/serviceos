{
  "name": "ServiceOS - Field Service Platform",
  "short_name": "ServiceOS",
  "description": "WhatsApp-first Field Service Operating System. Replace WhatsApp chaos, Excel trackers, and paper forms with one powerful platform.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0f172a",
  "theme_color": "#10b981",
  "orientation": "any",
  "categories": ["business", "productivity", "utilities"],
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "url": "/?view=dashboard",
      "icons": [{ "src": "/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Inbox",
      "short_name": "Inbox",
      "url": "/?view=inbox",
      "icons": [{ "src": "/icon.svg", "sizes": "any" }]
    },
    {
      "name": "New Lead",
      "short_name": "Leads",
      "url": "/?view=leads",
      "icons": [{ "src": "/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Jobs",
      "short_name": "Jobs",
      "url": "/?view=jobs",
      "icons": [{ "src": "/icon.svg", "sizes": "any" }]
    },
    {
      "name": "Calendar",
      "short_name": "Calendar",
      "url": "/?view=calendar",
      "icons": [{ "src": "/icon.svg", "sizes": "any" }]
    }
  ],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "launch_handler": {
    "client_mode": "navigate-existing"
  }
}
